# Copie para .env e preencha. NÃO versione o .env real.
# Tudo aqui é OPCIONAL: sem .env, o pipeline roda em modo DEMO com os defaults abaixo.

# ── Langfuse (dados reais) ────────────────────────────────────────────────────
# https://cloud.langfuse.com -> Settings -> API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Caminho do banco SQLite (compartilhado com o Evidence). Default: ./bsc_ia.db
# BSC_DB_PATH=/caminho/absoluto/bsc_ia.db

# ── Custo de IA ───────────────────────────────────────────────────────────────
# Preço médio da API por 1.000 tokens (R$): usado no VRT/kT e no custo simulado.
PRECO_API_POR_1K=0.025

# ── Benchmarks macro (VPL/TIR/ILL) — ajuste com os valores correntes ──────────
SELIC_ANUAL=0.105      # SELIC a.a. (Brasil)
US_RATE_ANUAL=0.045    # Fed funds a.a. (EUA)
USD_BRL=5.40           # câmbio BRL por USD (dolarização do fluxo)
IOF_PCT=3.5            # IOF % sobre compras internacionais (cartão)

# ── Monte Carlo ───────────────────────────────────────────────────────────────
MC_ITERACOES=10000     # iterações por projeto
MC_BINS=100            # classes do histograma
MC_SEED=42             # semente -> simulação reprodutível
MC_VAR_PCT=0.30        # caudas da Triangular: ±30% do fluxo base

# ── Robustez do ranking (perturbação de Dirichlet nos pesos do DEMATEL) ───────
MC_ROBUSTEZ_ITER=2000  # universos de preferência simulados
MC_ROBUSTEZ_KAPPA=200  # concentração: maior = pesos mais fiéis ao original
