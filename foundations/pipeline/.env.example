# Copie para .env e preencha. NÃO versione o .env real.
# Credenciais Langfuse (https://cloud.langfuse.com -> Settings -> API Keys)
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Caminho do banco SQLite (compartilhado com o Evidence). Default: ./bsc_ia.db
# BSC_DB_PATH=/caminho/absoluto/bsc_ia.db

# Preço médio da API por 1.000 tokens (R$) usado no cálculo do VRT/kT.
PRECO_API_POR_1K=0.025
